# ============================================================
# 汎用 .gitignore サンプル
# ============================================================

# ---------------------------
# OS 生成ファイル
# ---------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ---------------------------
# エディタ / IDE
# ---------------------------
.vscode/
.idea/
.claude/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.sublime-project
*.sublime-workspace

# ---------------------------
# 依存関係
# ---------------------------
node_modules/
vendor/
.pnp
.pnp.js

# ---------------------------
# ビルド成果物
# ---------------------------
dist/
build/
out/
.next/
.nuxt/
.cache/
*.egg-info/
__pycache__/
*.pyc
*.pyo
*.class
*.o
*.a

# ---------------------------
# 環境変数 / シークレット
# ---------------------------
.env
.env.local
.env.*.local
*.pem
*.key
secrets.json

# ---------------------------
# ログ・一時ファイル
# ---------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tmp
*.temp
*.bak
*.orig

# ---------------------------
# テスト・カバレッジ
# ---------------------------
coverage/
.nyc_output/
*.lcov
htmlcov/
.pytest_cache/

# ---------------------------
# パッケージマネージャのロックファイル (任意)
# ---------------------------
# package-lock.json
# yarn.lock

# ---------------------------
# その他
# ---------------------------
*.zip
*.tar.gz
*.rar


CLAUDE.md
AGENT.md
